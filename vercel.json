{
  "outputDirectory": "dist",
  "buildCommand": "npm run build",
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/weekly-blog",
      "schedule": "0 9 * * 1"
    }
  ],
  "redirects": [
    { "source": "/server.cjs", "destination": "/" },
    { "source": "/server.cjs.map", "destination": "/" },
    { "source": "/server/(.*)", "destination": "/" }
  ],
  "rewrites": [
    { "source": "/hakkimizda", "destination": "/" },
    { "source": "/hizmetler", "destination": "/" },
    { "source": "/yedek-parca", "destination": "/" },
    { "source": "/blog", "destination": "/" },
    { "source": "/blog/:slug", "destination": "/" },
    { "source": "/galeri", "destination": "/" },
    { "source": "/iletisim", "destination": "/" },
    { "source": "/marka/:slug", "destination": "/" },
    { "source": "/sayfa/:slug", "destination": "/" },
    { "source": "/yedek-parca/:slug", "destination": "/" },
    { "source": "/sehir/:sehir/yedek-parca", "destination": "/" },
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/sitemap.xml", "destination": "/api/index.ts" },
    { "source": "/robots.txt", "destination": "/api/index.ts" },
    { "source": "/((?!assets|_vercel|favicon|robots|sitemap|api).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.puter.com https://www.googletagmanager.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.fcs.com.tr https://pasamotor.com.tr https://*.supabase.co https://via.placeholder.com; connect-src 'self' https://*.supabase.co https://js.puter.com https://www.google-analytics.com https://*.vercel-insights.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'" },
        { "key": "X-Robots-Tag", "value": "noai, noimageai" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.supabase.co; connect-src 'self' https://*.supabase.co https://*.vercel-insights.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
